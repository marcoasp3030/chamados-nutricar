# ===== Variáveis de produção (NÃO COMMITAR) =====
# Copie para .env.production na VPS e preencha.

# Banco
POSTGRES_PASSWORD=troque-esta-senha-forte
DATABASE_URL=postgres://app:troque-esta-senha-forte@db:5432/app

# Auth
JWT_SECRET=gere-com-openssl-rand-base64-48
SESSION_COOKIE_NAME=chamados_session
SESSION_TTL_DIAS=30

# Storage local
STORAGE_DIR=/data/storage
STORAGE_URL_SECRET=gere-com-openssl-rand-base64-48
APP_BASE_URL=https://chamados.seu-dominio.com

# Domínio (Caddy)
DOMAIN=chamados.seu-dominio.com

# IA / integrações
OPENAI_API_KEY=
VMPAY_API_KEY=

# Lovable AI Gateway (opcional)
LOVABLE_API_KEY=
